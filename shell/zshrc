ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE="fg=244"  # Gray text for suggestions (subtle)

# ============================================================
# fzf Integration
# ============================================================
# [JP] fzf: 高速インタラクティブファジーファインダー（pecoから移行）
# [EN] fzf: Fast interactive fuzzy finder (migrated from peco)
#
# Ctrl+R : 履歴をfzfで検索（fzf組み込み）
# Ctrl+T : カレントディレクトリのファイルを選択してCLIに貼り付け（fzf組み込み）
# Alt+C  : サブディレクトリにfzfでジャンプ（fzf組み込み）
# Ctrl+G : ghqリポジトリにfzfでジャンプ（functions.zsh で定義）
# Ctrl+E : 最近訪問したディレクトリにfzfでジャンプ（functions.zsh で定義）
# Ctrl+X : サブディレクトリにfzfでジャンプ（functions.zsh で定義）
# ff     : カレントのファイルをfzfで選択 → nvimで開く（functions.zsh で定義）
# fr     : ghqリポジトリ選択 → ファイル選択 → nvimで開く（functions.zsh で定義）

# fd を使ってfzfのデフォルトコマンドを高速化（.gitignore 尊重, 隠しファイル含む）
export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'
export FZF_DEFAULT_OPTS='--height=40% --layout=reverse --border=rounded --info=inline'
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
export FZF_ALT_C_COMMAND='fd --type d --hidden --follow --exclude .git'

# [JP] fzf シェル統合: Ctrl+R/T と Alt+C を自動設定（brew --prefix で動的解決）
if command -v fzf >/dev/null && command -v brew >/dev/null; then
  _FZF_SHELL="$(brew --prefix 2>/dev/null)/opt/fzf/shell"
  [ -f "$_FZF_SHELL/completion.zsh" ]   && source "$_FZF_SHELL/completion.zsh"
  [ -f "$_FZF_SHELL/key-bindings.zsh" ] && source "$_FZF_SHELL/key-bindings.zsh"
  unset _FZF_SHELL
fi

# ============================================================
# cdr Setup（最近訪問ディレクトリの追跡）
# ============================================================
# Ctrl+E の fzf-cdr 関数（functions.zsh）が cdr コマンドを使用するため先に初期化
if [[ -n $(echo ${^fpath}/chpwd_recent_dirs(N)) && -n $(echo ${^fpath}/cdr(N)) ]]; then
  autoload -Uz chpwd_recent_dirs cdr add-zsh-hook
  add-zsh-hook chpwd chpwd_recent_dirs
  zstyle ':completion:*' recent-dirs-insert both
  zstyle ':chpwd:*' recent-dirs-default true
  zstyle ':chpwd:*' recent-dirs-max 1000
  zstyle ':chpwd:*' recent-dirs-file "$HOME/.cache/chpwd-recent-dirs"
fi

# ============================================================
# History Options (Tier 1 Optimization)
# ============================================================
# Purpose:
#   - Keep command history searchable and clean
#   - Share history across multiple zsh sessions
#   - Reduce clutter from test commands and duplicates
#
# History file location (follows XDG spec)
HISTFILE="${XDG_STATE_HOME:-$HOME/.local/state}/zsh/history"
HISTSIZE=100000       # Lines to keep in memory
SAVEHIST=1000000      # Lines to save to disk (10x for long-term reference)

# Create history directory if not exists
mkdir -p "$(dirname "$HISTFILE")"

# History behavior
setopt APPEND_HISTORY          # Append to history file instead of replacing (safer)
setopt SHARE_HISTORY           # Each session appends and reads from others (multi-terminal aware)

# History deduplication
setopt HIST_IGNORE_DUPS        # Skip duplicate entries (don't repeat same command)
setopt HIST_IGNORE_SPACE       # Skip commands starting with space (private: `<space>password=secret`)
setopt HIST_EXPIRE_DUPS_FIRST  # When full, delete oldest duplicate entry first
setopt HIST_FIND_NO_DUPS       # history search (Ctrl+R) doesn't show duplicates
setopt HIST_SAVE_NO_DUPS       # Don't write duplicate lines to disk

# ============================================================
# Shell Options (Tier 1 Optimization)
# ============================================================
# Purpose: Quality-of-life improvements for interactive shell usage
#
setopt AUTO_CD               # Type directory name to cd into it (no 'cd' needed)
setopt AUTO_PARAM_KEYS       # Auto-insert closing bracket/quote when needed
setopt NOBEEP                # Suppress bell sound on errors (quieter experience)
setopt NUMERIC_GLOB_SORT     # Numeric sort: file10 after file9, not after file1

