# Terminal Integration
# ============================================================
test -e "${HOME}/.iterm2_shell_integration.zsh" && source "${HOME}/.iterm2_shell_integration.zsh"

# ============================================================
# Language Version Managers (Lazy Load)
# ============================================================
export PYENV_ROOT="$HOME/.pyenv"
if [ -d "$PYENV_ROOT/bin" ]; then
  export PATH="$PYENV_ROOT/bin:$PATH"
fi

export GOENV_ROOT="$HOME/.goenv"
if [ -d "$GOENV_ROOT/bin" ]; then
  export PATH="$GOENV_ROOT/bin:$PATH"
fi

# Lazy initialize version managers on first use
_init_version_managers() {
  if command -v pyenv >/dev/null; then
    eval "$(pyenv init -)"
  fi
  if command -v rbenv >/dev/null; then
    eval "$(rbenv init -)"
  fi
  if command -v goenv >/dev/null; then
    eval "$(goenv init -)"
  fi
  unset -f _init_version_managers
}
alias python='_init_version_managers; python'
alias ruby='_init_version_managers; ruby'
alias go='_init_version_managers; go'

# ============================================================
# Cloud & DevTools
# ============================================================
if [ -d "/opt/homebrew/share/google-cloud-sdk" ]; then
  source "/opt/homebrew/share/google-cloud-sdk/completion.zsh.inc"
  source "/opt/homebrew/share/google-cloud-sdk/path.zsh.inc"
fi

