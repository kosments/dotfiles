# ============================================================
# Completions (Tier 1 Optimization)
# ============================================================
# Purpose:
#   - Completion system for tab-completion of commands, options, file paths
#   - compinit: Initialize zsh completion system
#
# Why cached:
#   - compinit scans all functions to build completion database
#   - Without cache: ~1s per shell startup (expensive!)
#   - With cache at ~/.cache/zsh/zcompdump: Fast subsequent startups
#   - Cache invalidates automatically when plugin versions change
#
# Create cache directory if not exists
mkdir -p "${XDG_CACHE_HOME:-$HOME/.cache}/zsh"

# Load completions with cache optimization
zinit ice wait'0'; zinit light zsh-users/zsh-completions
autoload -Uz compinit
compinit -d "${XDG_CACHE_HOME:-$HOME/.cache}/zsh/zcompdump"

# UX: Make completion match lowercase to uppercase
# Example: typing "doc" can complete to "Documents"
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Z}'

# UX: Interactive menu selection (select with arrow keys)
zstyle ':completion:*:default' menu select=1

